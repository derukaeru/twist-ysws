; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="twist-ysws"
run/main_scene="uid://bsbyp1yds8yl8"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameManager="*uid://d3t2qo2fhaj0e"
Registry="*uid://bc5qt0p3hime3"
SceneChanger="*uid://mftmsar637v6"
Util="*uid://cl4mktmg7kcgy"
EventBus="*uid://bn6xpwao041fv"

[debug]

gdscript/warnings/unused_signal=0

[display]

window/size/viewport_width=288
window/size/viewport_height=352
window/stretch/mode="viewport"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_super-wakatime/plugin.cfg")

[global_group]

player=""
projectile_container=""
bullet=""
player_bullet=""
alien=""
world_collision=""

[gui]

theme/custom_font="uid://dhlvoote4g4mn"

[input]

shoot={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":32,"key_label":0,"unicode":32,"location":0,"echo":false,"script":null)
]
}

[physics]

